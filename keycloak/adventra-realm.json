{
  "id": "adventra-realm",
  "realm": "adventra",
  "displayName": "Adventra Realm (Local Dev)",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": true,
  "verifyEmail": false,
  "rememberMe": true,
  "smtpServer": {
    "host": "smtp.sendgrid.net",
    "port": "587",
    "from": "no-reply@adventra.org",
    "fromDisplayName": "Adventra.org",
    "replyTo": "support@adventra.org",
    "auth": "true",
    "starttls": "true",
    "ssl": "false",
    "user": "apikey",
    "password": "[SENDGRID GOES HERE]"
  },
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10,
      "config": {}
    },
    {
      "alias": "webauthn-register",
      "name": "WebAuthn Register",
      "providerId": "webauthn-register",
      "enabled": true,
      "defaultAction": false,
      "priority": 20,
      "config": {
        "userVerificationRequirement": "preferred",
        "authenticatorAttachment": "platform",
        "requireResidentKey": "false",
        "signatureAlgorithms": "[\"ES256\"]",
        "attestationConveyancePreference": "none",
        "rpEntityName": "Adventra.org"
      }
    }
  ],
  "bruteForceProtected": false,
  "clients": [
    {
      "clientId": "adventra-mobile",
      "name": "Adventra Mobile App",
      "description": "React Native mobile app (iOS and Android)",
      "enabled": true,
      "publicClient": true,
      "clientAuthenticatorType": "client-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "adventra://callback",
        "adventra://oauth/callback",
        "adventra://auth/callback",
        "org.adventra.app://callback",
        "org.adventra.app://oauth/callback",
        "exp://localhost:19000/--/*",
        "exp://localhost:8081/--/*",
        "http://localhost:19006/*",
        "http://localhost:8081/*"
      ],
      "webOrigins": [
        "adventra://*",
        "org.adventra.app://*",
        "exp://localhost:19000",
        "exp://localhost:8081",
        "http://localhost:19006",
        "http://localhost:8081"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "adventra://logout+org.adventra.app://logout",
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "adventra-api",
      "name": "Adventra Backend API",
      "description": "Rust backend API and Python AI service",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "[PASSWORD GOES HERE]",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:8000/*",
        "http://localhost:8001/*",
        "http://localhost:8088/*",
        "http://127.0.0.1:8000/*",
        "http://127.0.0.1:8001/*",
        "http://127.0.0.1:8088/*",

        "https://dev.adventra.org/*",
        "https://api-dev.adventra.org/*",
        "https://ai-dev.adventra.org/*",

        "https://staging.adventra.org/*",
        "https://api-staging.adventra.org/*",
        "https://ai-staging.adventra.org/*",

        "https://adventra.org/*",
        "https://api.adventra.org/*",
        "https://ai.adventra.org/*",
        "https://www.adventra.org/*"
      ],
      "webOrigins": [
        "http://localhost:8000",
        "http://localhost:8001",
        "http://localhost:8088",
        "http://127.0.0.1:8000",
        "http://127.0.0.1:8001",
        "http://127.0.0.1:8088",
        "https://dev.adventra.org",
        "https://api-dev.adventra.org",
        "https://ai-dev.adventra.org",
        "https://staging.adventra.org",
        "https://api-staging.adventra.org",
        "https://ai-staging.adventra.org",
        "https://adventra.org",
        "https://api.adventra.org",
        "https://ai.adventra.org",
        "https://www.adventra.org"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    },
    {
      "clientId": "adventra-admin",
      "name": "Adventra Admin Console",
      "description": "Admin console for managing realms and users",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "[PASSWORD GOES HERE]",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:8000/*",
        "http://localhost:8001/*",
        "http://127.0.0.1:3000/*",
        "http://127.0.0.1:8000/*",
        "http://127.0.0.1:8001/*",

        "https://dev.adventra.org/*",
        "https://admin-dev.adventra.org/*",

        "https://staging.adventra.org/*",
        "https://admin-staging.adventra.org/*",

        "https://adventra.org/*",
        "https://admin.adventra.org/*",
        "https://www.adventra.org/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:8000",
        "http://localhost:8001",
        "http://127.0.0.1:3000",
        "http://127.0.0.1:8000",
        "http://127.0.0.1:8001",
        "https://dev.adventra.org",
        "https://admin-dev.adventra.org",
        "https://staging.adventra.org",
        "https://admin-staging.adventra.org",
        "https://adventra.org",
        "https://admin.adventra.org",
        "https://www.adventra.org"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "email": "admin@adventra.org",
      "credentials": [
        {
          "type": "password",
          "value": "[PASSWORD GOES HERE]",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"],
      "clientRoles": {
        "realm-management": [
          "realm-admin"
        ]
      }
    },
    {
      "username": "service-account-adventra-api",
      "enabled": true,
      "serviceAccountClientId": "adventra-api",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users",
          "query-users"
        ]
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full administrative access to Adventra platform"
      },
      {
        "name": "moderator",
        "description": "User with moderation privileges"
      },
      {
        "name": "verified_user",
        "description": "Verified user with access to LLM features"
      },
      {
        "name": "premium_user",
        "description": "Premium subscriber with enhanced token limits"
      },
      {
        "name": "user",
        "description": "Standard Adventra user"
      }
    ]
  }
}